DATABASE_URL="postgresql://postgres:postgres@localhost:5432/premgiri_books?schema=public"

APP_NAME="Premgiri Books ERP"

APP_VERSION="1.0.0"

NODE_ENV="development"

# Password for the bootstrap "admin" user created by `pnpm prisma db seed`
# (07-authentication.md forbids a registration screen, so this seeds the
# first Administrator). Falls back to a documented local-dev default if
# unset — always set this explicitly outside local development.
SEED_ADMIN_PASSWORD=
