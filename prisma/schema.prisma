// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Shared Field Convention (documentation only — not yet applied to every model)
//
// Every future business model (Customer, Product, Voucher, etc.) should follow
// this convention:
//
// Required
//   id         String   @id @default(uuid())
//   createdAt  DateTime @default(now())
//   updatedAt  DateTime @updatedAt
//
// Optional (add when the model needs them)
//   createdBy  String?
//   updatedBy  String?
//   deletedAt  DateTime?
//   remarks    String?
//
// The foundation models below only implement the required fields; optional
// audit/soft-delete fields are documented here for later phases to reuse.
// -----------------------------------------------------------------------------

model Company {
  id              String   @id @default(uuid())
  companyName     String
  legalName       String
  displayName     String?
  businessType    String?
  gstin           String?  @unique
  pan             String?
  tan             String?
  cin             String?
  mobileNumber    String?
  alternateMobile String?
  email           String?
  website         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  district        String?
  country         String   @default("India")
  pinCode         String?
  currency        String   @default("INR")
  currencySymbol  String   @default("₹")
  decimalPlaces   Int      @default(2)
  logo            String?
  timeZone        String   @default("Asia/Kolkata")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  settings       CompanySettings?
  financialYears FinancialYear[]
  branches       Branch[]
  users          User[]

  @@index([companyName])
}

model CompanySettings {
  id             String   @id @default(uuid())
  companyId      String   @unique
  defaultTheme   String   @default("dark")
  dateFormat     String   @default("DD/MM/YYYY")
  timeFormat     String   @default("24h")
  numberFormat   String   @default("en-IN")
  currencyFormat String   @default("INR")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model FinancialYear {
  id        String   @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId, isCurrent])
}

model Branch {
  id              String   @id @default(uuid())
  companyId       String
  branchName      String
  branchCode      String
  address         String?
  contactNumber   String?
  gstRegistration String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, branchCode])
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  fullName  String
  email     String   @unique
  mobile    String?
  isActive  Boolean  @default(true)
  companyId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@index([companyId])
  @@index([roleId])
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}
