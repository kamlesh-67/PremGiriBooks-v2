// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Shared Field Convention (documentation only — not yet applied to every model)
//
// Every future business model (Customer, Product, Voucher, etc.) should follow
// this convention:
//
// Required
//   id         String   @id @default(uuid())
//   createdAt  DateTime @default(now())
//   updatedAt  DateTime @updatedAt
//
// Optional (add when the model needs them)
//   createdBy  String?
//   updatedBy  String?
//   deletedAt  DateTime?
//   remarks    String?
//
// The foundation models below only implement the required fields; optional
// audit/soft-delete fields are documented here for later phases to reuse.
// -----------------------------------------------------------------------------

model Company {
  id               String   @id @default(uuid())
  companyName      String
  legalName        String
  displayName      String?
  businessType     String?
  gstin            String?  @unique
  pan              String?
  tan              String?
  cin              String?
  mobileNumber     String?
  alternateMobile  String?
  email            String?
  website          String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  district         String?
  country          String   @default("India")
  pinCode          String?
  currency         String   @default("INR")
  currencySymbol   String   @default("₹")
  decimalPlaces    Int      @default(2)
  logo             String?
  timeZone         String   @default("Asia/Kolkata")
  isActive         Boolean  @default(true)
  // Lets a future ERP upgrade detect a company seeded by an older
  // TenantBootstrapService version (missing a newer default role/permission/
  // master) without a manual migration. Only the column exists today — no
  // detect-and-backfill logic reads it yet; see
  // architecture-Migration-Super-Admin-Administration-Implementation-Plan.md.
  bootstrapVersion Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  settings          CompanySettings?
  financialYears    FinancialYear[]
  branches          Branch[]
  users             User[]
  roles             Role[]
  ledgerGroups      LedgerGroup[]
  ledgers           Ledger[]
  bankAccounts      BankAccount[]
  units             Unit[]
  categories        Category[]
  brands            Brand[]
  hsnCodes          HsnCode[]
  gstRates          GstRate[]
  warehouses        Warehouse[]
  products          Product[]
  marginProfiles    MarginProfile[]
  priceLists        PriceList[]
  customers         Customer[]
  suppliers         Supplier[]
  auditLogs         AuditLog[]
  documentSequences DocumentSequence[]
  vouchers          Voucher[]
  stockTransactions StockTransaction[]

  @@index([companyName])
}

model CompanySettings {
  id                 String   @id @default(uuid())
  companyId          String   @unique
  defaultTheme       String   @default("dark")
  dateFormat         String   @default("DD/MM/YYYY")
  timeFormat         String   @default("24h")
  numberFormat       String   @default("en-IN")
  currencyFormat     String   @default("INR")
  // Inventory Engine's negative-stock gate (32-inventory-engine.md;
  // code-standards.md "Negative stock depends on company settings") — when
  // false (default), an OUT movement that would take current stock below
  // zero is rejected; when true, it is allowed and stock reads back
  // negative.
  allowNegativeStock Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model FinancialYear {
  id        String   @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  documentSequences DocumentSequence[]
  vouchers          Voucher[]

  @@unique([companyId, name])
  @@index([companyId, isCurrent])
}

model Branch {
  id              String   @id @default(uuid())
  companyId       String
  branchName      String
  branchCode      String
  address         String?
  contactNumber   String?
  gstRegistration String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  warehouses Warehouse[]

  // Referenced by Warehouse's composite tenant-safe FK (companyId, branchId)
  // → (companyId, id); Postgres requires a unique constraint covering the
  // referenced column pair. Redundant with id's PK for lookups, load-bearing
  // for the FK.
  @@unique([companyId, id])
  @@unique([companyId, branchCode])
}

// context/feature-specs/architecture-Migration-Super-Admin-Administration.md
// (implementation detail recorded in the matching
// -Implementation-Plan.md) introduces a PLATFORM vs COMPANY split (Super
// Admin vs Company Admin/Company Users) on top of the prior single-
// Administrator model. A PLATFORM user (Super Admin) never belongs to a
// company or holds a Role — companyId/roleId are nullable for exactly that
// case. A COMPANY user always has both.
enum UserType {
  PLATFORM
  COMPANY
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  fullName     String
  email        String   @unique
  mobile       String?
  passwordHash String
  isActive     Boolean  @default(true)
  userType     UserType @default(COMPANY)
  companyId    String?
  roleId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id])
  role     Role?     @relation(fields: [roleId], references: [id])
  sessions Session[]
  vouchers Voucher[]

  @@index([companyId])
  @@index([roleId])
  @@index([userType])
}

// Roles are per-company (no shared/global rows) — every company gets its own
// private clone of the 6 reserved default roles, seeded by
// TenantBootstrapService at company-creation time. The pre-migration global
// roles were backfilled into per-company copies and every existing User's
// roleId was repointed (architecture-Migration-Super-Admin-Administration-
// Implementation-Plan.md's Phase 8) before this column became required.
//
// isSystemDefined: this is one of the 6 reserved default roles for its
// company (Company Admin/Accountant/Sales/Purchase/Store Manager/Employee).
// isProtected: rename/delete/deactivate/mandatory-permission protection is
// enforced for this row. Kept independent from isSystemDefined (rather than
// derived from it) so a future feature could protect a hand-created custom
// role without redefining what "system default" means — today every
// isSystemDefined role is seeded with isProtected: true and no custom role
// ever is.
model Role {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String
  isSystemDefined Boolean  @default(false)
  isProtected     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id        String   @id @default(uuid())
  module    String
  action    String
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

enum AccountNature {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

model LedgerGroup {
  id                 String        @id @default(uuid())
  companyId          String
  company            Company       @relation(fields: [companyId], references: [id])
  name               String
  parentGroupId      String?
  parentGroup        LedgerGroup?  @relation("LedgerGroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups        LedgerGroup[] @relation("LedgerGroupHierarchy")
  natureType         AccountNature
  affectsGrossProfit Boolean       @default(false)
  isSystemDefined    Boolean       @default(false)
  isActive           Boolean       @default(true)
  remarks            String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  ledgers Ledger[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentGroupId])
}

enum BalanceType {
  DEBIT
  CREDIT
}

model Ledger {
  id                 String      @id @default(uuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  ledgerGroupId      String
  ledgerGroup        LedgerGroup @relation(fields: [ledgerGroupId], references: [id])
  name               String
  openingBalance     Decimal     @default(0) @db.Decimal(14, 2)
  openingBalanceType BalanceType @default(DEBIT)
  description        String?
  isSystemDefined    Boolean     @default(false)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  bankAccount    BankAccount?
  customer       Customer?
  supplier       Supplier?
  voucherEntries VoucherEntry[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([ledgerGroupId])
}

enum BankAccountType {
  SAVINGS
  CURRENT
  CASH_CREDIT
  OVERDRAFT
}

// A strict 1:1 extension of Ledger (ledgerId @unique) — the display name,
// opening balance, and active/inactive state live on the Ledger row;
// BankAccount only adds the fields a generic Ledger has no room for.
// companyId duplicates ledger.companyId (a deliberate denormalization
// matching every other model's direct companyId column in this codebase),
// kept in sync only because BankAccount and its Ledger are always created
// and updated together in the same transaction (15-bank-management.md),
// never independently.
model BankAccount {
  id                String          @id @default(uuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  ledgerId          String          @unique
  ledger            Ledger          @relation(fields: [ledgerId], references: [id])
  bankName          String
  accountNumber     String
  ifscCode          String
  branchName        String
  accountHolderName String
  accountType       BankAccountType @default(CURRENT)
  upiId             String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([companyId, accountNumber])
  @@index([companyId])
}

// Unit of measure master (19-unit-management.md) — the first Inventory
// Masters table. `symbol` is the short form printed on documents ("PCS"),
// unique per company independently of `name` so two units can never print
// identically. `uqcCode` is the optional GST Unit Quantity Code GSTR-1's HSN
// summary needs per line — a plain optional string until the GST Engine
// (phase-tracker #31) formalizes it. No isSystemDefined and no seeding:
// unlike the chart of accounts, nothing structurally depends on any
// particular unit existing, so every unit is user-created.
model Unit {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  name          String
  symbol        String
  uqcCode       String?
  decimalPlaces Int      @default(0)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]

  @@unique([companyId, name])
  @@unique([companyId, symbol])
  @@index([companyId])
}

// Product classification tree (20-category-management.md) — the "Stock
// Group" concept Product Management (phase-tracker #23) will assign every
// product to. `name` is unique per company across the whole tree (not merely
// among siblings), matching LedgerGroup's rule and required for an
// unambiguous flat lookup in the Product form. Unlike LedgerGroup, the
// parent is editable after creation — a Category carries no inherited
// classification, so re-parenting only changes presentation/grouping; the
// service owns the resulting cycle-prevention obligation. No isSystemDefined
// and no seeding, for the same reason as Unit: nothing structurally depends
// on any particular category existing.
model Category {
  id               String     @id @default(uuid())
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id])
  name             String
  parentCategoryId String?
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  childCategories  Category[] @relation("CategoryHierarchy")
  description      String?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  products         Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentCategoryId])
}

// Brand/manufacturer master (21-brand-management.md) — publishers in the
// book trade, paint manufacturers in the future formula-management vertical.
// The flat, company-scoped label Product Management (phase-tracker #23) will
// assign products to. No isSystemDefined and no seeding, same reasoning as
// Unit: nothing structurally depends on any particular brand existing. No
// hierarchy either — unlike Categories, brands have no grouping semantics
// anywhere in this ERP's plans (YAGNI).
model Brand {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
}

// HSN for goods, SAC for services (22-hsn-management.md) — the Product
// Architecture supports Trading Product / Service / Expense Item product
// types, so the master holds both code families from day one.
enum HsnCodeType {
  HSN
  SAC
}

// HSN/SAC code master (22-hsn-management.md) — the tax-classification codes
// Product Management (phase-tracker #23) will reference and the GST Engine
// (#31) / GSTR-1's HSN Summary (#57) will consume per invoice line. `code` is
// unique per company across BOTH code types (HSN and SAC ranges don't
// meaningfully collide, and one uniqueness rule keeps the lookup
// unambiguous). `description` is required — GSTR-1's HSN Summary reports a
// description per code line, and a bare number is meaningless in the Product
// form's picker. Company-scoped (not global) per the tenant-isolation rule,
// and no seeding of the official directory: each business maintains only the
// handful of codes it trades in, same reasoning as Unit. No default GST rate
// here — the GST Engine owns HSN→rate mapping, same deferral as Unit's
// uqcCode.
model HsnCode {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  code        String
  codeType    HsnCodeType @default(HSN)
  description String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  products    Product[]

  @@unique([companyId, code])
  @@index([companyId])
}

// GST rate slab master (23-gst-rate-management.md) — the rate slabs Product
// Management (phase-tracker #23) will assign to products and the GST Engine
// (#31) will read to compute CGST/SGST/IGST and cess on documents. Stores
// only the TOTAL rate plus cess: the CGST+SGST/IGST split is pure arithmetic
// (half/half vs full) owned exclusively by the GST Engine, so storing the
// components would duplicate derivable data. `name` (not the numbers) is the
// display label pickers and documents show, unique per company; duplicate
// percentages under different names are deliberately allowed. Decimal(5,2)
// matches the codebase's Decimal-for-money/percentage convention
// (Ledger.openingBalance), and two decimals are required for the statutory
// 0.25% slab. No isSystemDefined and no seeding — slabs change by government
// notification and nothing depends structurally on any particular row
// existing, same reasoning as Unit.
model GstRate {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  ratePercent Decimal   @db.Decimal(5, 2)
  cessPercent Decimal   @default(0) @db.Decimal(5, 2)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@unique([companyId, name])
  @@index([companyId])
}

// Warehouse master (24-warehouse-management.md) — the physical stock
// locations (godowns/stores) Product Management (phase-tracker #23), the
// Inventory Engine (#30), Opening Stock (#44), and Stock Transfer (#46) will
// reference. `code` is the short identifier printed on stock documents
// (e.g. "WH-MAIN"), unique per company independently of `name`, mirroring
// Branch.branchCode and Unit's name/symbol pairing. `branchId` is optional
// because zero-branch companies are fully supported (12-branch-management.md
// rule); it ties the warehouse to a branch for future branch-wise stock
// reporting. `address` is a single free-text field — structured warehouse
// address deliberately deferred, same decision as Branch. `isDefault` — at
// most one per company — is service-enforced (Serializable transaction, not
// a DB constraint: Prisma's schema language cannot express a partial unique
// index portably; mirrors FinancialYear.isCurrent). No isSystemDefined and
// no seeding — nothing depends structurally on a warehouse row existing,
// same reasoning as Unit. No delete anywhere — Activate/Deactivate only.
model Warehouse {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  // Composite tenant-safe FK (review fix, 2026-07-18): relating
  // (companyId, branchId) → Branch(companyId, id) makes the DB itself reject
  // a cross-company branch link, as defense-in-depth behind the repository's
  // assertAssignableBranch check. MATCH SIMPLE semantics keep the branchless
  // (branchId NULL) case fully supported. Prisma emits ON DELETE RESTRICT
  // here (a required column is part of the FK) — fine, since branches are
  // never deleted anywhere in this codebase (Activate/Deactivate only).
  branchId      String?
  branch        Branch?  @relation(fields: [companyId, branchId], references: [companyId, id])
  name          String
  code          String
  address       String?
  contactNumber String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products          Product[]
  stockTransactions StockTransaction[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
}

// Trading Product / Service / Expense Item per architecture-context.md's
// Product Architecture (25-product-management.md). FORMULA is deliberately
// NOT added — it is reserved for the future manufacturing release, and
// adding an enum value later is a trivial migration (YAGNI).
enum ProductType {
  TRADING
  SERVICE
  EXPENSE
}

// Product/item master (25-product-management.md) — the master every
// stock-bearing and billing feature (Sales #41, Purchase #42, Inventory
// Engine #30, Pricing Engine #28, Opening Stock #44, Barcode Billing #76)
// will reference. Master data ONLY: reference prices (mrp / sellingPrice /
// purchasePrice) are plain stored data — every derived price is the Pricing
// Engine's job and every quantity movement is the Inventory Engine's
// (architecture-context.md Invariants 6–7). `purchasePrice` is the
// manually-entered starting value for the "Latest Purchase Cost" costing
// strategy; the Purchase module (#42) will later overwrite it on each
// purchase. `productCode` is the required user-entered SKU (no
// auto-numbering — the Document Number Engine #32 owns numbering);
// `barcode` is optional and unique per company when present (Postgres
// composite unique treats NULLs as distinct, so many products may omit it) —
// stored now so Barcode Billing has data to build on. `unitId` is required
// for every type, including services (billed in Hours/Nos/Jobs); the other
// classification links are optional — not every business classifies every
// product, exempt/unregistered scenarios exist, and single-location shops
// may never create a warehouse. `minStockLevel` is Decimal(14,4) because
// quantities honor the unit's decimalPlaces (0–4). Once the Inventory
// Engine records movements for a product, `unitId` and `productType` must
// become immutable (changing them would silently re-denominate history) —
// nothing to check against yet. No isSystemDefined and no seeding, same
// reasoning as every Inventory Master since Unit. No delete anywhere —
// Activate/Deactivate only.
model Product {
  id                 String         @id @default(uuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  name               String
  productCode        String
  barcode            String?
  productType        ProductType    @default(TRADING)
  categoryId         String?
  category           Category?      @relation(fields: [categoryId], references: [id])
  brandId            String?
  brand              Brand?         @relation(fields: [brandId], references: [id])
  unitId             String
  unit               Unit           @relation(fields: [unitId], references: [id])
  hsnCodeId          String?
  hsnCode            HsnCode?       @relation(fields: [hsnCodeId], references: [id])
  gstRateId          String?
  gstRate            GstRate?       @relation(fields: [gstRateId], references: [id])
  defaultWarehouseId String?
  defaultWarehouse   Warehouse?     @relation(fields: [defaultWarehouseId], references: [id])
  marginProfileId    String?
  marginProfile      MarginProfile? @relation(fields: [marginProfileId], references: [id])
  mrp                Decimal?       @db.Decimal(14, 2)
  sellingPrice       Decimal?       @db.Decimal(14, 2)
  purchasePrice      Decimal?       @db.Decimal(14, 2)
  minStockLevel      Decimal?       @db.Decimal(14, 4)
  description        String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  priceListItems    PriceListItem[]
  stockTransactions StockTransaction[]

  @@unique([companyId, name])
  @@unique([companyId, productCode])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([marginProfileId])
}

// Named, reusable percentage-based pricing rule (28-margin-profiles.md,
// PRD.md §12) the Pricing Engine (#28) will apply to a product's latest
// purchase cost to derive tier-wise selling prices. Stores data only — no
// price is calculated here or anywhere in this module
// (architecture-context.md Invariant 6, Engine Driven). One percentage per
// CustomerType tier, all four required — a company pricing every tier
// identically simply enters the same number four times. calculationMode is
// stored per profile (not per company) so mixed strategies are possible.
// Percentages are Decimal(5,2); the MARGIN-mode < 100 bound (the formula
// divides by 1 − p/100) and the MARKUP-mode ≤ 999.99 bound are enforced in
// Zod only (mode-dependent superRefine) — no DB CHECK, matching GstRate's
// convention. No isSystemDefined and no seeding, no rounding configuration,
// no category/brand-level defaults — all deliberately deferred (YAGNI). No
// delete anywhere — Activate/Deactivate only, same as every master since
// Units.
model MarginProfile {
  id                 String               @id @default(uuid())
  companyId          String
  company            Company              @relation(fields: [companyId], references: [id])
  name               String
  calculationMode    PriceCalculationMode @default(MARGIN)
  retailPercent      Decimal              @db.Decimal(5, 2)
  wholesalePercent   Decimal              @db.Decimal(5, 2)
  dealerPercent      Decimal              @db.Decimal(5, 2)
  distributorPercent Decimal              @db.Decimal(5, 2)
  description        String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
}

// Named collection of fixed selling prices (29-price-lists.md, PRD.md §587)
// the Pricing Engine (#28) will consult BEFORE falling back to margin
// calculation. Pure master data — no price resolution (which list wins,
// quantity-break selection, date-window selection) lives here or anywhere in
// this module (architecture-context.md Invariant 6, Engine Driven).
// customerType null = tier-agnostic, applies to any customer the Pricing
// Engine routes to it. effectiveFrom/effectiveTo (both optional, inclusive
// calendar days) are the promotional-pricing primitive — a Diwali list is
// just a list with a window; overlapping windows across lists are legal by
// design, the Pricing Engine's resolution order decides among
// simultaneously-effective lists. No isSystemDefined and no seeding. No
// delete — Activate/Deactivate only, same as every master since Units.
model PriceList {
  id            String        @id @default(uuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  name          String
  customerType  CustomerType?
  effectiveFrom DateTime?     @db.Date
  effectiveTo   DateTime?     @db.Date
  description   String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items     PriceListItem[]
  customers Customer[]

  @@unique([companyId, name])
  @@index([companyId])
}

// A price row within a PriceList — the quantity-pricing primitive:
// (priceListId, productId, minQuantity) unique means one product may carry
// several rows ("1+ -> price A, 10+ -> price B"); the Pricing Engine picks
// the highest break <= ordered quantity (not implemented here). Deliberately
// carries NO companyId — an item is reachable only through its parent list,
// every repository query joins through priceListId, and the parent's
// companyId is the single tenant anchor. Item rows ARE hard-deletable
// (unlike every other master's child data) — a detail line of an editable
// master, not a business record with history; nothing references a row, and
// Sales documents will snapshot the resolved price at posting time rather
// than referencing it (the HSN snapshot-at-posting precedent).
model PriceListItem {
  id           String    @id @default(uuid())
  priceListId  String
  priceList    PriceList @relation(fields: [priceListId], references: [id])
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  sellingPrice Decimal   @db.Decimal(14, 2)
  minQuantity  Decimal   @default(1) @db.Decimal(14, 4)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([priceListId, productId, minQuantity])
  @@index([priceListId])
  @@index([productId])
}

// The Pricing Engine's (#28) two company-choosable ways to derive a selling
// price from a product's latest purchase cost (PRD.md §12):
// MARKUP: sellingPrice = cost × (1 + percent / 100)
// MARGIN: sellingPrice = cost / (1 − percent / 100)
// Not implemented here — MarginProfile only stores the choice.
enum PriceCalculationMode {
  MARGIN
  MARKUP
}

// The pricing tier the Pricing Engine (#28) and Price Lists (#27) will key
// on (26-customer-management.md) — stored as plain data here, no pricing
// behavior attaches to it in the Customer master itself.
enum CustomerType {
  RETAIL
  WHOLESALE
  DEALER
  DISTRIBUTOR
}

// Permanent Customer master (26-customer-management.md) — a strict 1:1
// extension of Ledger (ledgerId @unique), exactly the BankAccount pattern
// with "Bank Accounts" swapped for "Sundry Debtors": the display name,
// opening balance/type, description, and active/inactive state live on the
// Ledger row; Customer only adds the party fields a generic Ledger has no
// room for. companyId duplicates ledger.companyId (the same deliberate
// denormalization as BankAccount), kept in sync only because the pair is
// always written together in one transaction, never independently. No
// customerCode — the customer's identity per company is the Ledger's name
// (@@unique([companyId, name]) already enforced); auto-numbered codes are
// the Document Number Engine's (#32) job. gstin is deliberately NOT unique:
// two customer records may legitimately share a GSTIN (two branches of the
// same registered buyer tracked as separate parties/ledgers). creditLimit/
// creditDays are plain stored data — enforcement is Sales Invoice (#36) /
// Voucher Engine (#29) territory. Quick and Walk-in customers get no row
// here by design (Sales Invoice #36 owns both). No isSystemDefined and no
// seeding — nothing structurally depends on any customer existing. No
// delete anywhere — Activate/Deactivate only.
model Customer {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  ledgerId        String       @unique
  ledger          Ledger       @relation(fields: [ledgerId], references: [id])
  customerType    CustomerType @default(RETAIL)
  contactPerson   String?
  mobileNumber    String?
  alternateMobile String?
  email           String?
  gstin           String?
  pan             String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  district        String?
  country         String       @default("India")
  pinCode         String?
  creditLimit     Decimal?     @db.Decimal(14, 2)
  creditDays      Int?
  priceListId     String?
  priceList       PriceList?   @relation(fields: [priceListId], references: [id])
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId])
  @@index([priceListId])
}

// Permanent Supplier master (27-supplier-management.md) — the credit-side
// mirror of Customer: a strict 1:1 extension of Ledger (ledgerId @unique)
// under "Sundry Creditors" instead of "Sundry Debtors". The display name,
// opening balance/type (defaulting to CREDIT for a creditor), description,
// and active/inactive state live on the Ledger row; Supplier only adds the
// party fields a generic Ledger has no room for. companyId duplicates
// ledger.companyId (the same deliberate denormalization as BankAccount/
// Customer), kept in sync only because the pair is always written together
// in one transaction, never independently. Two deliberate omissions versus
// Customer: no supplierType — the RETAIL/WHOLESALE/DEALER/DISTRIBUTOR tiers
// exist for the selling-side Pricing Engine and nothing prices purchases by
// supplier tier (YAGNI); and no creditLimit — a credit limit is a cap WE
// impose on a debtor, what a supplier extends to us is their decision, so
// storing it would be dead data. creditDays (agreed payment terms) is kept —
// Purchase Invoice (#42) and payables ageing will consume it. No
// supplierCode (Document Number Engine #32's job); gstin deliberately NOT
// unique (two branches of one registered vendor may share a GSTIN). No
// isSystemDefined and no seeding — nothing structurally depends on any
// supplier existing. No delete anywhere — Activate/Deactivate only.
model Supplier {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  ledgerId        String   @unique
  ledger          Ledger   @relation(fields: [ledgerId], references: [id])
  contactPerson   String?
  mobileNumber    String?
  alternateMobile String?
  email           String?
  gstin           String?
  pan             String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  district        String?
  country         String   @default("India")
  pinCode         String?
  creditDays      Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
}

// Scoped narrowly to the Administration-side tenant-lifecycle events the
// Super Admin migration itself introduces (Company Created/Updated, Company
// Admin Created/Updated/Reassigned, Company Activated/Deactivated, Company
// Admin Password Reset/Activated/Deactivated), plus Bank Account
// Activated/Deactivated (bank-accounts module) — not a general audit-log
// retrofit across every existing module. That broader "Write Audit Log" gap
// remains separately tracked in architecture-context.md's Known
// Implementation Gaps.
model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([actorUserId])
  @@index([targetType, targetId])
}

model Session {
  id     String @id @default(uuid())
  userId String

  // Optional context per 07-authentication.md — Company/Branch/Financial Year
  // selection remain their own cookie-based mechanisms (current-company.ts,
  // current-financial-year.ts); these columns exist to match the spec's
  // session data shape but are not populated by this phase.
  companyId       String?
  branchId        String?
  financialYearId String?

  rememberMe Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Forward-declarative catalog covering every numbered document on the phase
// tracker (34-document-number-engine.md) — the Document Number Engine's
// contract, mirroring the DEFAULT_ROLE_PERMISSIONS precedent of listing
// entries for modules that don't exist yet. Every one of the Voucher
// Engine's (spec 31) ten VoucherTypes maps 1:1 to its own dedicated
// `*_VOUCHER` entry — a document and the voucher it generates are two
// separately numbered things.
enum DocumentType {
  QUOTATION
  SALES_ORDER
  DELIVERY_CHALLAN
  SALES_INVOICE
  SALES_RETURN
  CREDIT_NOTE
  DEBIT_NOTE
  PURCHASE_ORDER
  GOODS_RECEIPT_NOTE
  PURCHASE_INVOICE
  PURCHASE_RETURN
  PAYMENT_VOUCHER
  RECEIPT_VOUCHER
  CONTRA_VOUCHER
  JOURNAL_VOUCHER
  SALES_VOUCHER
  PURCHASE_VOUCHER
  CREDIT_NOTE_VOUCHER
  DEBIT_NOTE_VOUCHER
  SALES_RETURN_VOUCHER
  PURCHASE_RETURN_VOUCHER
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
}

// One row per (company, financial year, document type) — the sole owner of
// sequential document numbering (34-document-number-engine.md). Lazily
// created on first use (ensureSequence); no seeding. No branchId — Branch
// Management (spec 12) is unimplemented, and a nullable column inside a
// composite unique creates the Postgres NULLs-are-distinct trap; a future
// migration adds the dimension deliberately when branches land.
model DocumentSequence {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id])
  documentType    DocumentType
  prefix          String
  padding         Int           @default(4)
  nextNumber      Int           @default(1)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, financialYearId, documentType])
  @@index([companyId])
}

enum VoucherType {
  PAYMENT
  RECEIPT
  CONTRA
  JOURNAL
  SALES
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
  SALES_RETURN
  PURCHASE_RETURN
}

enum VoucherStatus {
  POSTED
  CANCELLED
}

// The double-entry accounting core (31-voucher-engine.md) — the single place
// ledger postings exist. Born POSTED (no draft status: the Document-Driven
// Draft->...->Posted lifecycle belongs to business documents, not vouchers)
// and immutable thereafter; cancellation creates a mirrored reversal instead
// of ever mutating a posted row. No `branchId` — Branch Management (spec 12)
// is unimplemented (same reasoning as DocumentSequence above).
model Voucher {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id])
  voucherType     VoucherType
  voucherNumber   String
  voucherDate     DateTime      @db.Date
  status          VoucherStatus @default(POSTED)
  narration       String?
  // Polymorphic link to the source document ("SALES_INVOICE", its id) — no FK
  // by design: voucher rows must outlive any referencing table's shape, and
  // the source-document tables don't exist yet. Manual vouchers (#50-#53)
  // leave both null.
  referenceType   String?
  referenceId     String?
  // Sum of debit entries (== credit sum) — denormalized for list rendering
  // only, never used in balance computation (entries are the truth).
  totalAmount     Decimal       @db.Decimal(14, 2)
  // Self-relation, @unique: a voucher is reversed at most once. The reversal
  // voucher's entries mirror the original with DEBIT<->CREDIT swapped.
  reversalOfId    String?       @unique
  reversalOf      Voucher?      @relation("VoucherReversal", fields: [reversalOfId], references: [id])
  reversedBy      Voucher?      @relation("VoucherReversal")
  createdByUserId String?
  createdBy       User?         @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  entries VoucherEntry[]

  @@unique([companyId, financialYearId, voucherType, voucherNumber])
  @@index([companyId, voucherDate])
  @@index([companyId, voucherType])
  @@index([referenceType, referenceId])
}

// No companyId here — reachable only through its Voucher; every query joins
// through Voucher (the spec-29 PriceListItem reasoning).
model VoucherEntry {
  id         String      @id @default(uuid())
  voucherId  String
  voucher    Voucher     @relation(fields: [voucherId], references: [id])
  ledgerId   String
  ledger     Ledger      @relation(fields: [ledgerId], references: [id])
  entryType  BalanceType
  amount     Decimal     @db.Decimal(14, 2)
  lineNumber Int

  @@unique([voucherId, lineNumber])
  @@index([ledgerId])
  @@index([voucherId])
}

// 32-inventory-engine.md — the Inventory Engine's own type/direction split,
// distinct from Voucher's BalanceType (DEBIT/CREDIT): stock movement is
// IN/OUT, always a positive quantity (current stock = Sigma IN - Sigma OUT,
// explicit over signed quantities).
enum StockTransactionType {
  OPENING_STOCK
  PURCHASE
  PURCHASE_RETURN
  SALES
  SALES_RETURN
  TRANSFER
  ADJUSTMENT
  PHYSICAL_VERIFICATION
}

enum StockDirection {
  IN
  OUT
}

// The single place stock movement exists (architecture-context.md Invariant
// 7; code-standards.md "Stock quantity must never be updated directly.
// Current stock is calculated from stock transactions") —
// 32-inventory-engine.md. No update/delete API exists anywhere for this
// model: corrections are opposite-direction ADJUSTMENT rows recorded by
// future screens (#45), mirroring VoucherEntry's immutability.
//
// No `financialYearId` — deliberate: stock is continuous across financial
// years (closing stock of one year IS opening stock of the next), unlike
// Voucher which is FY-scoped. `referenceType`/`referenceId` is a polymorphic
// source-document link with no FK, same reasoning as Voucher — source
// document tables (#36, #41, #42) don't exist yet. `transferGroupId` links
// one transfer's OUT and IN rows (exactly two rows sharing one value,
// written atomically by `transferStock`); null for every other type.
// `unitCost` is an optional snapshot (set by purchases/opening stock, null
// where meaningless) — stored data, NOT used for valuation today (Latest
// Purchase Cost reads `Product.purchasePrice` instead); kept for a future
// FIFO/Weighted-Average costing method that cannot be computed
// retroactively without per-movement cost history.
model StockTransaction {
  id              String               @id @default(uuid())
  companyId       String
  company         Company              @relation(fields: [companyId], references: [id])
  productId       String
  product         Product              @relation(fields: [productId], references: [id])
  warehouseId     String
  warehouse       Warehouse            @relation(fields: [warehouseId], references: [id])
  transactionType StockTransactionType
  direction       StockDirection
  quantity        Decimal              @db.Decimal(14, 4)
  unitCost        Decimal?             @db.Decimal(14, 2)
  transactionDate DateTime             @db.Date
  referenceType   String?
  referenceId     String?
  transferGroupId String?
  narration       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([companyId, productId, warehouseId])
  @@index([companyId, transactionDate])
  @@index([referenceType, referenceId])
  @@index([transferGroupId])
}
