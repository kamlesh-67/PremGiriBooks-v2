// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Shared Field Convention (documentation only — not yet applied to every model)
//
// Every future business model (Customer, Product, Voucher, etc.) should follow
// this convention:
//
// Required
//   id         String   @id @default(uuid())
//   createdAt  DateTime @default(now())
//   updatedAt  DateTime @updatedAt
//
// Optional (add when the model needs them)
//   createdBy  String?
//   updatedBy  String?
//   deletedAt  DateTime?
//   remarks    String?
//
// The foundation models below only implement the required fields; optional
// audit/soft-delete fields are documented here for later phases to reuse.
// -----------------------------------------------------------------------------

model Company {
  id               String   @id @default(uuid())
  companyName      String
  legalName        String
  displayName      String?
  businessType     String?
  gstin            String?  @unique
  pan              String?
  tan              String?
  cin              String?
  mobileNumber     String?
  alternateMobile  String?
  email            String?
  website          String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  district         String?
  country          String   @default("India")
  pinCode          String?
  currency         String   @default("INR")
  currencySymbol   String   @default("₹")
  decimalPlaces    Int      @default(2)
  logo             String?
  timeZone         String   @default("Asia/Kolkata")
  isActive         Boolean  @default(true)
  // Lets a future ERP upgrade detect a company seeded by an older
  // TenantBootstrapService version (missing a newer default role/permission/
  // master) without a manual migration. Only the column exists today — no
  // detect-and-backfill logic reads it yet; see
  // architecture-Migration-Super-Admin-Administration-Implementation-Plan.md.
  bootstrapVersion Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  settings       CompanySettings?
  financialYears FinancialYear[]
  branches       Branch[]
  users          User[]
  roles          Role[]
  ledgerGroups   LedgerGroup[]
  ledgers        Ledger[]
  bankAccounts   BankAccount[]
  units          Unit[]
  categories     Category[]
  brands         Brand[]
  hsnCodes       HsnCode[]
  gstRates       GstRate[]
  warehouses     Warehouse[]
  auditLogs      AuditLog[]

  @@index([companyName])
}

model CompanySettings {
  id             String   @id @default(uuid())
  companyId      String   @unique
  defaultTheme   String   @default("dark")
  dateFormat     String   @default("DD/MM/YYYY")
  timeFormat     String   @default("24h")
  numberFormat   String   @default("en-IN")
  currencyFormat String   @default("INR")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model FinancialYear {
  id        String   @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId, isCurrent])
}

model Branch {
  id              String   @id @default(uuid())
  companyId       String
  branchName      String
  branchCode      String
  address         String?
  contactNumber   String?
  gstRegistration String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  warehouses Warehouse[]

  @@unique([companyId, branchCode])
}

// context/feature-specs/architecture-Migration-Super-Admin-Administration.md
// (implementation detail recorded in the matching
// -Implementation-Plan.md) introduces a PLATFORM vs COMPANY split (Super
// Admin vs Company Admin/Company Users) on top of the prior single-
// Administrator model. A PLATFORM user (Super Admin) never belongs to a
// company or holds a Role — companyId/roleId are nullable for exactly that
// case. A COMPANY user always has both.
enum UserType {
  PLATFORM
  COMPANY
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  fullName     String
  email        String   @unique
  mobile       String?
  passwordHash String
  isActive     Boolean  @default(true)
  userType     UserType @default(COMPANY)
  companyId    String?
  roleId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id])
  role     Role?     @relation(fields: [roleId], references: [id])
  sessions Session[]

  @@index([companyId])
  @@index([roleId])
  @@index([userType])
}

// Roles are per-company (no shared/global rows) — every company gets its own
// private clone of the 6 reserved default roles, seeded by
// TenantBootstrapService at company-creation time. The pre-migration global
// roles were backfilled into per-company copies and every existing User's
// roleId was repointed (architecture-Migration-Super-Admin-Administration-
// Implementation-Plan.md's Phase 8) before this column became required.
//
// isSystemDefined: this is one of the 6 reserved default roles for its
// company (Company Admin/Accountant/Sales/Purchase/Store Manager/Employee).
// isProtected: rename/delete/deactivate/mandatory-permission protection is
// enforced for this row. Kept independent from isSystemDefined (rather than
// derived from it) so a future feature could protect a hand-created custom
// role without redefining what "system default" means — today every
// isSystemDefined role is seeded with isProtected: true and no custom role
// ever is.
model Role {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String
  isSystemDefined Boolean  @default(false)
  isProtected     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id        String   @id @default(uuid())
  module    String
  action    String
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

enum AccountNature {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

model LedgerGroup {
  id                 String        @id @default(uuid())
  companyId          String
  company            Company       @relation(fields: [companyId], references: [id])
  name               String
  parentGroupId      String?
  parentGroup        LedgerGroup?  @relation("LedgerGroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups        LedgerGroup[] @relation("LedgerGroupHierarchy")
  natureType         AccountNature
  affectsGrossProfit Boolean       @default(false)
  isSystemDefined    Boolean       @default(false)
  isActive           Boolean       @default(true)
  remarks            String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  ledgers Ledger[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentGroupId])
}

enum BalanceType {
  DEBIT
  CREDIT
}

model Ledger {
  id                 String      @id @default(uuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  ledgerGroupId      String
  ledgerGroup        LedgerGroup @relation(fields: [ledgerGroupId], references: [id])
  name               String
  openingBalance     Decimal     @default(0) @db.Decimal(14, 2)
  openingBalanceType BalanceType @default(DEBIT)
  description        String?
  isSystemDefined    Boolean     @default(false)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  bankAccount BankAccount?

  @@unique([companyId, name])
  @@index([companyId])
  @@index([ledgerGroupId])
}

enum BankAccountType {
  SAVINGS
  CURRENT
  CASH_CREDIT
  OVERDRAFT
}

// A strict 1:1 extension of Ledger (ledgerId @unique) — the display name,
// opening balance, and active/inactive state live on the Ledger row;
// BankAccount only adds the fields a generic Ledger has no room for.
// companyId duplicates ledger.companyId (a deliberate denormalization
// matching every other model's direct companyId column in this codebase),
// kept in sync only because BankAccount and its Ledger are always created
// and updated together in the same transaction (15-bank-management.md),
// never independently.
model BankAccount {
  id                String          @id @default(uuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  ledgerId          String          @unique
  ledger            Ledger          @relation(fields: [ledgerId], references: [id])
  bankName          String
  accountNumber     String
  ifscCode          String
  branchName        String
  accountHolderName String
  accountType       BankAccountType @default(CURRENT)
  upiId             String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([companyId, accountNumber])
  @@index([companyId])
}

// Unit of measure master (19-unit-management.md) — the first Inventory
// Masters table. `symbol` is the short form printed on documents ("PCS"),
// unique per company independently of `name` so two units can never print
// identically. `uqcCode` is the optional GST Unit Quantity Code GSTR-1's HSN
// summary needs per line — a plain optional string until the GST Engine
// (phase-tracker #31) formalizes it. No isSystemDefined and no seeding:
// unlike the chart of accounts, nothing structurally depends on any
// particular unit existing, so every unit is user-created.
model Unit {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  name          String
  symbol        String
  uqcCode       String?
  decimalPlaces Int      @default(0)
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, name])
  @@unique([companyId, symbol])
  @@index([companyId])
}

// Product classification tree (20-category-management.md) — the "Stock
// Group" concept Product Management (phase-tracker #23) will assign every
// product to. `name` is unique per company across the whole tree (not merely
// among siblings), matching LedgerGroup's rule and required for an
// unambiguous flat lookup in the Product form. Unlike LedgerGroup, the
// parent is editable after creation — a Category carries no inherited
// classification, so re-parenting only changes presentation/grouping; the
// service owns the resulting cycle-prevention obligation. No isSystemDefined
// and no seeding, for the same reason as Unit: nothing structurally depends
// on any particular category existing.
model Category {
  id               String     @id @default(uuid())
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id])
  name             String
  parentCategoryId String?
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  childCategories  Category[] @relation("CategoryHierarchy")
  description      String?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentCategoryId])
}

// Brand/manufacturer master (21-brand-management.md) — publishers in the
// book trade, paint manufacturers in the future formula-management vertical.
// The flat, company-scoped label Product Management (phase-tracker #23) will
// assign products to. No isSystemDefined and no seeding, same reasoning as
// Unit: nothing structurally depends on any particular brand existing. No
// hierarchy either — unlike Categories, brands have no grouping semantics
// anywhere in this ERP's plans (YAGNI).
model Brand {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

// HSN for goods, SAC for services (22-hsn-management.md) — the Product
// Architecture supports Trading Product / Service / Expense Item product
// types, so the master holds both code families from day one.
enum HsnCodeType {
  HSN
  SAC
}

// HSN/SAC code master (22-hsn-management.md) — the tax-classification codes
// Product Management (phase-tracker #23) will reference and the GST Engine
// (#31) / GSTR-1's HSN Summary (#57) will consume per invoice line. `code` is
// unique per company across BOTH code types (HSN and SAC ranges don't
// meaningfully collide, and one uniqueness rule keeps the lookup
// unambiguous). `description` is required — GSTR-1's HSN Summary reports a
// description per code line, and a bare number is meaningless in the Product
// form's picker. Company-scoped (not global) per the tenant-isolation rule,
// and no seeding of the official directory: each business maintains only the
// handful of codes it trades in, same reasoning as Unit. No default GST rate
// here — the GST Engine owns HSN→rate mapping, same deferral as Unit's
// uqcCode.
model HsnCode {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  code        String
  codeType    HsnCodeType @default(HSN)
  description String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

// GST rate slab master (23-gst-rate-management.md) — the rate slabs Product
// Management (phase-tracker #23) will assign to products and the GST Engine
// (#31) will read to compute CGST/SGST/IGST and cess on documents. Stores
// only the TOTAL rate plus cess: the CGST+SGST/IGST split is pure arithmetic
// (half/half vs full) owned exclusively by the GST Engine, so storing the
// components would duplicate derivable data. `name` (not the numbers) is the
// display label pickers and documents show, unique per company; duplicate
// percentages under different names are deliberately allowed. Decimal(5,2)
// matches the codebase's Decimal-for-money/percentage convention
// (Ledger.openingBalance), and two decimals are required for the statutory
// 0.25% slab. No isSystemDefined and no seeding — slabs change by government
// notification and nothing depends structurally on any particular row
// existing, same reasoning as Unit.
model GstRate {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  ratePercent Decimal  @db.Decimal(5, 2)
  cessPercent Decimal  @default(0) @db.Decimal(5, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

// Warehouse master (24-warehouse-management.md) — the physical stock
// locations (godowns/stores) Product Management (phase-tracker #23), the
// Inventory Engine (#30), Opening Stock (#44), and Stock Transfer (#46) will
// reference. `code` is the short identifier printed on stock documents
// (e.g. "WH-MAIN"), unique per company independently of `name`, mirroring
// Branch.branchCode and Unit's name/symbol pairing. `branchId` is optional
// because zero-branch companies are fully supported (12-branch-management.md
// rule); it ties the warehouse to a branch for future branch-wise stock
// reporting. `address` is a single free-text field — structured warehouse
// address deliberately deferred, same decision as Branch. `isDefault` — at
// most one per company — is service-enforced (Serializable transaction, not
// a DB constraint: Prisma's schema language cannot express a partial unique
// index portably; mirrors FinancialYear.isCurrent). No isSystemDefined and
// no seeding — nothing depends structurally on a warehouse row existing,
// same reasoning as Unit. No delete anywhere — Activate/Deactivate only.
model Warehouse {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  name          String
  code          String
  address       String?
  contactNumber String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
}

// Scoped narrowly to the Administration-side tenant-lifecycle events the
// Super Admin migration itself introduces (Company Created/Updated, Company
// Admin Created/Updated/Reassigned, Company Activated/Deactivated, Company
// Admin Password Reset/Activated/Deactivated), plus Bank Account
// Activated/Deactivated (bank-accounts module) — not a general audit-log
// retrofit across every existing module. That broader "Write Audit Log" gap
// remains separately tracked in architecture-context.md's Known
// Implementation Gaps.
model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([actorUserId])
  @@index([targetType, targetId])
}

model Session {
  id     String @id @default(uuid())
  userId String

  // Optional context per 07-authentication.md — Company/Branch/Financial Year
  // selection remain their own cookie-based mechanisms (current-company.ts,
  // current-financial-year.ts); these columns exist to match the spec's
  // session data shape but are not populated by this phase.
  companyId       String?
  branchId        String?
  financialYearId String?

  rememberMe Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
